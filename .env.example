# Azure AD / Entra ID (frontend)
# Default frontend auth mode is Entra ID.
# Fill in the Entra values below for normal application use.
# Leave all mock settings commented out unless you are intentionally running local test auth.
VITE_AZURE_CLIENT_ID=your-client-id-here
VITE_AZURE_TENANT_ID=your-tenant-id-here
VITE_AZURE_API_SCOPE=api://your-client-id/access_as_user

# Optional test-only frontend auth bypass
# Do not enable these for normal development or production.
# To temporarily switch the frontend to mock auth for deterministic local testing:
# 1. Uncomment VITE_TEST_AUTH_MODE=mock
# 2. Uncomment VITE_TEST_USER and choose a seeded persona (for example: admin, viewer, editor, intake_manager)
# 3. Restart the frontend dev server
# Leave these commented to keep Entra ID sign-in as the default.
# VITE_TEST_AUTH_MODE=mock
# VITE_TEST_USER=admin
