{
    "name": "digital-health-atlas-api",
    "version": "1.0.0",
    "description": "Express API for Digital Health Atlas with SQL Server",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "start": "node index.js",
        "dev": "node --watch index.js",
        "setup-db": "node scripts/setup_db.js",
        "setup-db:full": "npm run setup-db && npm run seed:permissions",
        "upgrade-db": "node scripts/upgrade_db.js",
        "migrate:all": "npm run upgrade-db",
        "seed:permissions": "node scripts/seed_permissions.js",
        "seed:faker": "node scripts/seed_faker.js",
        "seed:performance": "node scripts/seed_performance.js",
        "setup-db:with-faker": "npm run setup-db:full && npm run seed:faker",
        "migrate:governance:phase0": "node scripts/run_migration.js migrate_governance_phase0.sql",
        "migrate:governance:phase1": "node scripts/run_migration.js migrate_governance_phase1.sql",
        "migrate:governance:phase2": "node scripts/run_migration.js migrate_governance_phase2.sql",
        "migrate:governance:phase3": "node scripts/run_migration.js migrate_governance_phase3.sql",
        "migrate:goal-description": "node scripts/run_migration.js migrate_goal_description.sql",
        "migrate:multi-org": "node scripts/run_migration.js migrate_multi_org.sql",
        "migrate:org-sharing-v2": "node scripts/run_migration.js migrate_org_sharing_v2.sql",
        "migrate:project-goals": "node scripts/run_migration.js migrate_project_goals.sql",
        "migrate:project-watchlist": "node scripts/run_migration.js migrate_project_watchlist.sql",
        "migrate:task-tracking:phase1": "node scripts/run_migration.js migrate_task_tracking_phase1.sql",
        "migrate:wave2": "node scripts/run_migration.js migrate_wave2.sql",
        "migrate:wave3": "node scripts/run_migration.js migrate_wave3.sql",
        "test:contracts": "node --test tests/contracts/*.test.js",
        "lint:rbac": "node scripts/check_permission_catalog.js"
    },
    "dependencies": {
        "@faker-js/faker": "^10.3.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.0",
        "helmet": "^8.1.0",
        "jwks-rsa": "^4.0.1",
        "mssql": "^12.2.0",
        "node-cache": "^5.1.2",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1"
    }
}
