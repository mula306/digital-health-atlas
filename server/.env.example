# --- Database (SQL Server) ---
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!
DB_SERVER=127.0.0.1
DB_PORT=1433
DB_NAME=DHAtlas

# --- Azure AD / Entra ID ---
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here

# --- Optional ---
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,https://admin.example.com
# AUTH_FALLBACK_ROLES=Viewer   # dev-only; must be empty in production
# AUTH_LAST_LOGIN_UPDATE_MS=300000 # minimum interval between lastLogin refreshes (default 5m)
# PRUNE_LEGACY_USER_ROLE=false # set true once to remove legacy 'User' RolePermissions rows
# SEED_PERMISSIONS_FORCE=false  # set true to overwrite existing RolePermissions with defaults on startup
# DB_ENCRYPT=false           # set true in production when using TLS
# DB_TRUST_SERVER_CERT=true  # set false in production with trusted cert chain
# DB_CONNECT_RETRIES=30      # setup-db SQL readiness retries
# DB_CONNECT_DELAY_MS=2000   # delay between setup-db retries
# FAKER_PROJECTS=40          # optional override for npm run seed:faker
# NODE_ENV=production
